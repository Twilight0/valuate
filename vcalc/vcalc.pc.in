prefix=@prefix@
exec_prefix=${prefix}
libdir=@libdir@
datadir=@prefix@/share
includedir=@prefix@/include

Name: libvcalc
Description: Valuate Libray
URL: http://live.gnome.org/
Version: @PROJECT_VERSION@
Requires: gio-2.0 >= 2.50 gee-0.8 >= 0.20
Libs: -L${libdir} -lvcalc-@API_VERSION@
Cflags: -I${includedir}/vcalc-@API_VERSION@
